# ===== REQUIRED =====
# Your Claude API Key from https://console.anthropic.com/settings/keys
# Using Claude Haiku (cheapest model)
CLAUDE_API_KEY=your_claude_api_key_here

# Your Google Service Account JSON (entire JSON as a single line string)
# Copy the contents of service_account.json and paste it here (as one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"...","client_email":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ===== OPTIONAL =====
# Google Drive Folder ID to restrict search to specific folder
# Leave empty to search across all files shared with service account
GOOGLE_DRIVE_FOLDER_ID=

# Base URL for download links (auto-detected in most deployments)
BASE_URL=
